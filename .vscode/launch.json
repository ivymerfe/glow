{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions"
      ],
      "cwd": "${workspaceFolder}/glow-vscode",
      "outFiles": ["${workspaceFolder}/glow-vscode/out/**/*.js"]
    }
  ]
}
