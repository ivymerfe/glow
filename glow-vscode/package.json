{
  "name": "glow",
  "displayName": "Glow",
  "version": "1.0.0",
  "module": "src/extension.ts",
  "type": "module",
  "private": true,
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:glow.previewShader"
  ],
  "contributes": {
    "commands": [
      {
        "command": "glow.previewShader",
        "title": "Glow: Preview Shader"
      }
    ],
    "configuration": {
      "title": "Glow",
      "properties": {
        "glow.executablePath": {
          "type": "string",
          "default": "glow",
          "description": "Path to the glow executable (or command name in PATH)."
        },
        "glow.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Extra arguments passed to glow."
        }
      }
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/vscode": "latest"
  },
  "engines": {
    "vscode": "^1.105.0",
    "bun": "1.3.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "build": "bun build ./src/extension.ts --outdir ./out --external=* --sourcemap=linked",
    "watch": "bun build ./src/extension.ts --outdir ./out --external=* --sourcemap=inline --watch"
  }
}
