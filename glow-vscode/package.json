{
  "name": "glow",
  "displayName": "Glow",
  "version": "1.0.1",
  "author": {
    "name": "ivy"
  },
  "publisher": "ivy",
  "module": "src/extension.ts",
  "type": "module",
  "private": true,
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "glow.preview",
        "title": "Glow: Start preview or toggle fullscreen"
      },
      {
        "command": "glow.stopPreview",
        "title": "Glow: Stop Preview"
      },
      {
        "command": "glow.restart",
        "title": "Glow: Restart"
      },
      {
        "command": "glow.compileModule",
        "title": "Glow: Compile Module"
      },
      {
        "command": "glow.compileToGlsl",
        "title": "Glow: Compile To GLSL"
      }
    ],
    "keybindings": [
      {
        "command": "glow.preview",
        "key": "ctrl+e",
        "when": "editorTextFocus && (editorLangId == slang || resourceExtname == .slang || resourceExtname == .slangh)"
      },
      {
        "command": "glow.stopPreview",
        "key": "ctrl+q",
        "when": "editorTextFocus && (editorLangId == slang || resourceExtname == .slang || resourceExtname == .slangh)"
      }
    ],
    "configuration": {
      "title": "Glow",
      "properties": {
        "glow.executablePath": {
          "type": "string",
          "default": "glow",
          "description": "Path to the glow executable"
        },
        "glow.args": {
          "type": "string",
          "default": "-width=1920 -height=1080 -max-images=32 -max-windows=8 -debug=false",
          "description": "Glow arguments"
        }
      }
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/vscode": "^1.105.0"
  },
  "engines": {
    "vscode": "^1.105.0",
    "bun": "1.3.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "build": "bun build ./src/extension.ts --outdir ./out --external=vscode --external=node:* --sourcemap=linked",
    "watch": "bun build ./src/extension.ts --outdir ./out --external=vscode --external=node:* --sourcemap=inline --watch"
  }
}
